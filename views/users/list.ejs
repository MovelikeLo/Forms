<!DOCTYPE html>
<html lang="en">
<head>
    <title>Document</title>
</head>
<body>
    <h1>Our Users List</h1>
    <table>
        <tr>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Age</th>
            <th>Gender</th>
        </tr>
        <% 
        let users = locals.users;
        for (user of users) { %>
        <tr>
            <td><%= user.firstName %></td>
            <td><%= user.lastName %></td>
            <td><%= user.age %></td>
            <td><%= user.gender %></td>
        </tr>
        <% } %>
    </table>
</body>
</html>