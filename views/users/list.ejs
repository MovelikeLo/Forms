<!DOCTYPE html>
<html lang="en">
<head>
    <title>Document</title>
</head>
<body>
    <h1>Our Users List</h1>
    <ul>
    <% 
        let users = locals.users;
        for (user of users) { %>
            <li><%= user.firstName %> <%= user.lastName %>, <%= user.age %>, <%= user.gender %></li>
   <% } %>
    </ul>
</body>
</html>